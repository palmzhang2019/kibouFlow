# Site origin used by robots.ts / sitemap.ts / OrganizationJsonLd / metadataBase.
# No trailing slash. Override per environment (dev/preview/prod).
NEXT_PUBLIC_SITE_URL=https://kibouflow.com

# GEO 体检后台（/zh/admin/login → /zh/admin/geo-audit）：密码 + 会话签名密钥（建议 32+ 随机字符）
ADMIN_GEO_PASSWORD=
ADMIN_SESSION_SECRET=

# PostgreSQL 连接串（试用/合作/埋点、GEO 配置与规则、体检历史等均走同一数据库）
# 示例：postgresql://postgres:password@127.0.0.1:5432/kibouflow
# DATABASE_URL=

# 自托管 PostgreSQL：请在目标库中按文件名序号执行 supabase/migrations/ 下全部 SQL（已不含 Supabase 专用 RLS）。

# 可选：体检脚本内调用 OpenAI 生成「LLM 附录」（需 OPENAI_API_KEY）
# GEO_AUDIT_USE_LLM=1
# OPENAI_API_KEY=
# GEO_AUDIT_OPENAI_MODEL=chatgpt-5.4-mini

# 可选：覆盖 Python 可执行文件路径（容器内默认 python3，Windows 开发机常为 python）
# GEO_AUDIT_PYTHON=python3

# 可选：CI/测试跳过真实执行子进程（仅返回占位结果）
# GEO_AUDIT_SKIP=1
